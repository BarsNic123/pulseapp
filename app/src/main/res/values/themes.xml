<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Pulse" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#1A73E8</item>
    </style>

    <style name="Theme.Pulse" parent="Base.Theme.Pulse" />

    <style name="FieldLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#757575</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="PulseInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@android:drawable/editbox_background</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">20dp</item>
        <item name="android:textColor">#212121</item>
    </style>

    <style name="PulseChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">#F5F5F5</item>
        <item name="android:textColor">#424242</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>
</resources>